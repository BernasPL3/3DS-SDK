#!/bin/bash

case "$1" in
  new)
    cp -r templates/basic "$2"
    echo "Projeto criado: $2"
    ;;

  build)
    mkdir -p build

    gcc source/*.c -o build/game

    echo "Build concluído!"
    ;;

  cia)
    makerom -f cia \
      -o build/game.cia \
      -elf build/game.elf
    ;;

  clean)
    rm -rf build
    ;;

  *)
    echo "3DS-SDK"
    echo "Comandos:"
    echo "  new <nome>"
    echo "  build"
    echo "  cia"
    echo "  clean"
    ;;
esac
