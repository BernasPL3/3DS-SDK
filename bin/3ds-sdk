#!/bin/bash

case "$1" in
  new)
    cp -r templates/basic "$2"
    echo "Projeto criado: $2"
    ;;


mkdir -p build

if ls source/*.cpp >/dev/null 2>&1; then
    echo "Compilando C++..."
    g++ source/*.cpp -o build/game
elif ls source/*.c >/dev/null 2>&1; then
    echo "Compilando C..."
    gcc source/*.c -o build/game
else
    echo "Nenhum arquivo .c ou .cpp encontrado em source/"
    exit 1
fi

  cia)
    makerom -f cia \
      -o build/game.cia \
      -elf build/game.elf
    ;;

  clean)
    rm -rf build
    ;;

  *)
    echo "3DS-SDK"
    echo "Comandos:"
    echo "  new <nome>"
    echo "  build"
    echo "  cia"
    echo "  clean"
    ;;
esac
